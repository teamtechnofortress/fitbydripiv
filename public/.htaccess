RewriteEngine On
DirectoryIndex index.html index.php

# 🔒 Block direct access to backend folder
RewriteRule ^backend/ - [F,L]

# 🔐 Block sensitive files
<FilesMatch "\.(env|log|ini|sh|sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ⚡ API requests → Laravel (index.php)
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteRule ^ index.php [L]

# 📁 Existing files/directories → Serve directly (assets, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 🎨 Everything else → Laravel serves Vue via index.php
# Laravel's web.php catch-all route returns index.html
RewriteRule ^ index.php [L]